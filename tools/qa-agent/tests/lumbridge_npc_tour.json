{
  "name": "Lumbridge NPC Dialogue Verification",
  "description": "Walk to each major NPC in Lumbridge, talk to them, verify dialog opens, report results.",
  "version": "1.0.0",
  "botName": "QA-TestBot",
  "spawnPoint": { "x": 3222, "z": 3222 },
  "tests": [
    {
      "name": "talk_to_hans",
      "description": "Walk to Hans in castle courtyard, talk to him",
      "steps": [
        { "action": "walk", "target": { "x": 3222, "z": 3219 } },
        { "action": "wait_for_position", "target": { "x": 3222, "z": 3219, "tolerance": 3 } },
        { "action": "interact_npc", "npcIndex": 0, "option": 1 },
        { "action": "wait_for_condition", "condition": "dialog_open", "timeout": 10000 },
        { "action": "get_state" },
        { "action": "wait_ticks", "ticks": 10 },
        { "action": "report", "step": "Talk to Hans", "expected": "Dialog opens" }
      ]
    },
    {
      "name": "talk_to_cook",
