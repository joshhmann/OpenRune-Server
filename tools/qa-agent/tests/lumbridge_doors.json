{
  "name": "Lumbridge Doors Verification (HYX-161 Regression)",
  "description": "Test every door in Lumbridge for responsiveness. Known issues from HYX-161: castle doors unresponsive, windmill door unresponsive, Wizards' Tower door unresponsive.",
  "version": "1.0.0",
  "botName": "QA-DoorTest",
  "spawnPoint": { "x": 3222, "z": 3222 },
  "tests": [
    {
      "name": "door_castle_main",
      "description": "Lumbridge castle main door (south entrance)",
      "steps": [
        { "action": "walk_with_doors", "target": { "x": 3212, "z": 3220 } },
        { "action": "wait_for_position", "target": { "x": 3212, "z": 3220, "tolerance": 2 } },
        { "action": "open_door", "target": { "x": 3212, "z": 3220 }, "timeout": 8000 },
        { "action": "wait_ticks", "ticks": 10 },
        { "action": "report", "step": "Castle main door", "expected": "Door opens" }
      ]
    },
    {
      "name": "door_castle_north",
